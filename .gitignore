# ============================================================================
# .gitignore — pi-lab
# Documentazione di riferimento per pi + script di utilità (Node/Python)
# ============================================================================


# ---------------------------------------------------------------------------
# Segreti e ambiente locale — MAI committare
# ---------------------------------------------------------------------------
.env
.env.*
# Template (senza valori reali) — si committano, NON sono segreti
!*.example
!*.sample
*.pem
*.key
*.p12


# ---------------------------------------------------------------------------
# pi — log, cache e dati locali
# Nota: .pi/extensions/ e .pi/stitch-proxy/ SONO codice di progetto e si committano.
# ---------------------------------------------------------------------------
.pi/logs/
.pi/npm/
.pi/git/
.pi/cache/
logs/


# ---------------------------------------------------------------------------
# Dipendenze e log dei package manager
# ---------------------------------------------------------------------------
node_modules/
.pnpm-store/
.yarn/cache
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/


# ---------------------------------------------------------------------------
# Output di build / bundle (comune a Node e Python)
# ---------------------------------------------------------------------------
dist/
build/
out/
*.tsbuildinfo


# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
# Bytecode e moduli compilati
__pycache__/
*.py[cod]
*$py.class
*.so

# Ambienti virtuali
.venv/
venv/
env/
ENV/

# Packaging / install-editable
*.egg
*.egg-info/
.eggs/
sdist/
wheels/

# Cache di test e type-checker
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.hypothesis/

# Jupyter
.ipynb_checkpoints/


# ---------------------------------------------------------------------------
# Editor / IDE (preferenze personali, non del progetto)
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~


# ---------------------------------------------------------------------------
# Sistema operativo
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ---------------------------------------------------------------------------
# Artefatti Windows accidentali (nomi di dispositivo riservati)
# ---------------------------------------------------------------------------
# Un redirect tipo `comando > nul` può creare un file fisico ``nul`` invece
# di andare al device null; git non riesce a indicizzarlo. Lo si ignora.
nul
